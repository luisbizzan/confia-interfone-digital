insert into public.verified_access_invitations(
  id, condominium_id, request_id, participant_slot_id, token_hash, status,
  expires_at, issued_at, created_by_user_id, created_at, updated_at
) values
(
  '77777777-3c3c-43c3-83c3-333333333331',
  '11111111-3c3c-43c3-83c3-333333333331',
  '55555555-3c3c-43c3-83c3-333333333331',
  '66666666-3c3c-43c3-83c3-333333333331',
  'v1:' || repeat('a', 64),
  'PENDING',
  now() - interval '1 hour',
  now() - interval '2 hours',
  '33333333-3c3c-43c3-83c3-333333333331',
  now() - interval '2 hours',
  now() - interval '2 hours'
),
(
  '77777777-3c3c-43c3-83c3-333333333332',
  '11111111-3c3c-43c3-83c3-333333333331',
  '55555555-3c3c-43c3-83c3-333333333331',
  '66666666-3c3c-43c3-83c3-333333333332',
  'v1:' || repeat('b', 64),
  'OPENED',
  now() + interval '1 day',
  now() - interval '2 hours',
  '33333333-3c3c-43c3-83c3-333333333331',
  now() - interval '2 hours',
  now() - interval '2 hours'
),
(
  '77777777-3c3c-43c3-83c3-333333333333',
  '11111111-3c3c-43c3-83c3-333333333331',
  '55555555-3c3c-43c3-83c3-333333333331',
  '66666666-3c3c-43c3-83c3-333333333333',
  'v1:' || repeat('c', 64),
