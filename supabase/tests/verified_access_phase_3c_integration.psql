insert into public.verified_access_public_sessions(
  id, condominium_id, request_id, invitation_id, participant_slot_id,
  session_token_hash, status, expires_at, created_at, updated_at
) values (
  '88888888-3c3c-43c3-83c3-333333333331',
  '11111111-3c3c-43c3-83c3-333333333331',
  '55555555-3c3c-43c3-83c3-333333333331',
  '77777777-3c3c-43c3-83c3-333333333332',
  '66666666-3c3c-43c3-83c3-333333333332',
  'v1:' || repeat('d', 64),
  'ACTIVE',
  now() - interval '90 minutes',
  now() - interval '2 hours',
  now() - interval '2 hours'
);

insert into public.verified_access_public_rate_limits(
  id, condominium_id, scope, subject_fingerprint, window_started_at,
  attempt_count, expires_at, created_at, updated_at
) values (
  '99999999-3c3c-43c3-83c3-333333333331',
  '11111111-3c3c-43c3-83c3-333333333331',
  'SESSION_GET',
  'v1:' || repeat('e', 64),
  now() - interval '4 hours',
  1,
  now() - interval '2 hours',
  now() - interval '4 hours',
  now() - interval '4 hours'
);

do $$
declare
  v_result jsonb;
begin
  v_result := public.verified_access_expire_invitations(
    10, true, 'phase3c-expire-dry-run'
  );
  if (v_result->>'processed')::integer <> 1 then
    raise exception 'dry-run did not report expired invitation';
  end if;
  if (
    select status
    from public.verified_access_invitations
    where id = '77777777-3c3c-43c3-83c3-333333333331'
  ) <> 'PENDING' then
    raise exception 'dry-run mutated invitation';
  end if;

  v_result := public.verified_access_expire_invitations(
    10, false, 'phase3c-expire-invitations'
  );
  if (v_result->>'processed')::integer <> 1 then
    raise exception 'invitation expiration failed';
  end if;
  if (
    select status
    from public.verified_access_invitations
    where id = '77777777-3c3c-43c3-83c3-333333333331'
  ) <> 'EXPIRED' then
    raise exception 'invitation did not expire';
  end if;

  v_result := public.verified_access_expire_invitations(
    10, false, 'phase3c-expire-replay'
  );
  if (v_result->>'processed')::integer <> 0 then
    raise exception 'invitation expiration is not idempotent';
  end if;

  v_result := public.verified_access_expire_public_sessions(
    10, false, 'phase3c-expire-sessions'
  );
  if (v_result->>'processed')::integer <> 1 then
    raise exception 'session expiration failed';
  end if;
  if (
    select status
    from public.verified_access_public_sessions
    where id = '88888888-3c3c-43c3-83c3-333333333331'
  ) <> 'EXPIRED' then
    raise exception 'public session did not expire';
  end if;

  v_result := public.verified_access_purge_rate_limit_buckets(
    10, false, 'phase3c-purge-rate-limits'
  );
  if (v_result->>'processed')::integer <> 1 then
    raise exception 'rate-limit purge failed';
  end if;

  v_result := public.verified_access_process_outbox(
    50, false, 'phase3c-process-outbox'
  );
  if (v_result->>'processed')::integer < 2 then
    raise exception 'local outbox handler did not process maintenance events';
  end if;
end
$$;

do $$
begin
  if not exists (
    select 1
    from public.verified_access_audit_events
    where aggregate_id = '77777777-3c3c-43c3-83c3-333333333331'
      and event_type = 'VERIFIED_ACCESS_INVITATION_EXPIRED'
  ) then
    raise exception 'invitation expiration audit missing';
  end if;

  if not exists (
    select 1
    from public.verified_access_outbox_events
    where aggregate_id = '77777777-3c3c-43c3-83c3-333333333331'
      and event_type = 'VERIFIED_ACCESS_INVITATION_EXPIRED'
      and status = 'PROCESSED'
  ) then
    raise exception 'invitation expiration outbox was not processed';
  end if;

  if exists (
    select 1
    from public.verified_access_audit_events
    where correlation_id like 'phase3c-%'
      and upper(metadata::text) ~ '(CPF|NAME|BIRTH|PHONE|TOKEN|PASSPORT|RNM)'
  ) then
    raise exception 'PII leaked to Phase 3C audit';
  end if;

  if exists (
    select 1
    from public.verified_access_outbox_events
    where deduplication_key like 'verified-access:maintenance:%'
      and upper(payload::text) ~ '(CPF|NAME|BIRTH|PHONE|TOKEN|PASSPORT|RNM)'
  ) then
    raise exception 'PII leaked to Phase 3C outbox';
  end if;

  if exists (
    select 1
    from public.condominium_features
    where condominium_id = '11111111-3c3c-43c3-83c3-333333333331'
      and feature_key = 'VERIFIED_ACCESS'
      and enabled
  ) then
    raise exception 'Phase 3C enabled feature';
  end if;
end
$$;

insert into public.verified_access_public_registration_commands(
  id, condominium_id, invitation_id, command_type, idempotency_key,
  input_fingerprint, status, created_at
) values (
  'aaaaaaaa-3c3c-43c3-83c3-333333333331',
  '11111111-3c3c-43c3-83c3-333333333331',
  '77777777-3c3c-43c3-83c3-333333333333',
  'EXCHANGE',
  'phase3c-stuck-command',
  'v1:' || repeat('f', 64),
  'PROCESSING',
  now() - interval '8 days'
);

do $$
declare
  v_result jsonb;
begin
  v_result := public.verified_access_reconcile_public_registration_state(
    50, false, 'phase3c-reconcile-state'
  );
  if (v_result->>'processed')::integer < 1 then
    raise exception 'reconciliation found no anomaly';
  end if;
  if not exists (
    select 1
    from public.verified_access_maintenance_findings
    where aggregate_id = 'aaaaaaaa-3c3c-43c3-83c3-333333333331'
      and finding_code = 'COMMAND_PROCESSING_STUCK'
      and status = 'OPEN'
  ) then
    raise exception 'stuck command finding missing';
  end if;
end
$$;

rollback;
