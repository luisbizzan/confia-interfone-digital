select pg_temp.expect_error($$insert into public.verified_access_participant_slots (condominium_id, request_id, slot_number) values ('11111111-aaaa-4000-8000-000000000001', '55555555-aaaa-4000-8000-000000000001', 1)$$, '23505', 'duplicate slot');
