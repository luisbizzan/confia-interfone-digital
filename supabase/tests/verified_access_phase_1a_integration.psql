insert into public.verified_access_outbox_events (
  condominium_id,
  aggregate_type,
  aggregate_id,
  event_type,
  deduplication_key,
  payload
)
values (
  '11111111-aaaa-4000-8000-000000000001',
  'REQUEST',
  '55555555-aaaa-4000-8000-000000000001',
  'REQUEST_CREATED',
  'verified-access-test-dedup',
  '{"event":"created","nested":{"codes":["A"]}}'::jsonb
);

update public.verified_access_outbox_events
set status = 'PROCESSING',
    attempts = attempts + 1,
    locked_at = now(),
    locked_by = 'ci',
    next_attempt_at = now() + interval '5 minutes',
    last_error_code = null,
    updated_at = now()
where deduplication_key = 'verified-access-test-dedup';

select pg_temp.expect_error($$insert into public.verified_access_outbox_events (condominium_id, aggregate_type, aggregate_id, event_type, deduplication_key, payload) values ('11111111-aaaa-4000-8000-000000000001', 'REQUEST', '55555555-aaaa-4000-8000-000000000001', 'REQUEST_CREATED', 'verified-access-test-dedup', '{"event":"created"}'::jsonb)$$, '23505', 'duplicate outbox key');
select pg_temp.expect_error($$insert into public.verified_access_outbox_events (condominium_id, aggregate_type, aggregate_id, event_type, deduplication_key, payload) values ('11111111-aaaa-4000-8000-000000000001', 'REQUEST', '55555555-aaaa-4000-8000-000000000001', 'REQUEST_CREATED', 'verified-access-token-test', '{"nested":{"Token":"secret"}}'::jsonb)$$, '23514', 'outbox token alias payload');
select pg_temp.expect_error($$insert into public.verified_access_outbox_events (condominium_id, aggregate_type, aggregate_id, event_type, deduplication_key, payload) values ('11111111-aaaa-4000-8000-000000000001', 'REQUEST', '55555555-aaaa-4000-8000-000000000001', 'REQUEST_CREATED', 'verified-access-array-test', '[]'::jsonb)$$, '23514', 'outbox payload object only');
select pg_temp.expect_error($$update public.verified_access_outbox_events set payload = '{"event":"mutated"}'::jsonb where deduplication_key = 'verified-access-test-dedup'$$, 'P0001', 'outbox business payload immutable');

insert into public.verified_access_audit_events (
  id,
  condominium_id,
  aggregate_type,
  aggregate_id,
  event_type,
  metadata
)
values (
  '99999999-aaaa-4000-8000-000000000001',
  '11111111-aaaa-4000-8000-000000000001',
  'REQUEST',
  '55555555-aaaa-4000-8000-000000000001',
  'REQUEST_CREATED',
  '{"event":"created"}'::jsonb
);

select pg_temp.expect_error($$insert into public.verified_access_audit_events (condominium_id, aggregate_type, aggregate_id, event_type, metadata) values ('11111111-aaaa-4000-8000-000000000001', 'REQUEST', '55555555-aaaa-4000-8000-000000000001', 'REQUEST_CREATED', '{"alias":{"doc_number":"00000000000"}}'::jsonb)$$, '23514', 'audit document alias metadata');
select pg_temp.expect_error($$insert into public.verified_access_audit_events (condominium_id, aggregate_type, aggregate_id, event_type, metadata) values ('11111111-aaaa-4000-8000-000000000001', 'REQUEST', '55555555-aaaa-4000-8000-000000000001', 'REQUEST_CREATED', '[]'::jsonb)$$, '23514', 'audit metadata object only');
select pg_temp.expect_error($$update public.verified_access_audit_events set metadata = '{"event":"mutated"}'::jsonb where id = '99999999-aaaa-4000-8000-000000000001'$$, 'P0001', 'audit update blocked');
select pg_temp.expect_error($$delete from public.verified_access_audit_events where id = '99999999-aaaa-4000-8000-000000000001'$$, 'P0001', 'audit delete blocked');
select pg_temp.expect_error($$truncate public.verified_access_audit_events$$, 'P0001', 'audit truncate blocked');

commit;
