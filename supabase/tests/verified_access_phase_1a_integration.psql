create or replace function pg_temp.expect_error(p_sql text, p_expected_sqlstate text, p_label text)
returns void
language plpgsql
as $$
begin
  execute p_sql;
  raise exception 'Expected % for %', p_expected_sqlstate, p_label
    using errcode = 'ZX001';
exception
  when others then
    if sqlstate <> p_expected_sqlstate then
      raise exception 'Expected %, got % for %', p_expected_sqlstate, sqlstate, p_label;
    end if;
end;
$$;

select pg_temp.expect_error($$insert into public.verified_access_policies (condominium_id, version, content_checksum, network_signal_rules) values ('11111111-aaaa-4000-8000-000000000001', 2, repeat('x', 64), '{"effect":"auto_deny_network"}'::jsonb)$$, '23514', 'forbidden network auto deny');
select pg_temp.expect_error($$insert into public.verified_access_policies (condominium_id, version, content_checksum, retention_settings) values ('11111111-aaaa-4000-8000-000000000001', 2, repeat('x', 64), '[]'::jsonb)$$, '23514', 'policy retention json must be object');
select pg_temp.expect_error($$insert into public.verified_access_policies (condominium_id, version, content_checksum, visitor_background_mode) values ('11111111-aaaa-4000-8000-000000000001', 2, repeat('x', 64), 'REQUIRED')$$, '23514', 'background mode requires approval reference');
