select pg_temp.expect_error($$insert into public.verified_access_requests (condominium_id, unit_id, requested_by_user_id, request_type, starts_at, ends_at, timezone, participant_limit, policy_id, policy_version) values ('11111111-aaaa-4000-8000-000000000001', '22222222-aaaa-4000-8000-000000000001', '33333333-bbbb-4000-8000-000000000001', 'VISITOR', now(), now() + interval '1 day', 'America/Sao_Paulo', 1, '44444444-aaaa-4000-8000-000000000001', 1)$$, '23503', 'cross-tenant request requester');
select pg_temp.expect_error($$insert into public.verified_access_requests (condominium_id, unit_id, requested_by_user_id, request_type, starts_at, ends_at, timezone, participant_limit, policy_id, policy_version) values ('11111111-aaaa-4000-8000-000000000001', '22222222-aaaa-4000-8000-000000000001', '33333333-aaaa-4000-8000-000000000001', 'VISITOR', now(), now() + interval '1 day', 'America/Sao_Paulo', 1, '44444444-bbbb-4000-8000-000000000001', 1)$$, '23503', 'cross-tenant request policy');
select pg_temp.expect_error($$insert into public.verified_access_requests (condominium_id, unit_id, requested_by_user_id, request_type, starts_at, ends_at, timezone, participant_limit, policy_id, policy_version) values ('11111111-aaaa-4000-8000-000000000001', '22222222-aaaa-4000-8000-000000000001', '33333333-aaaa-4000-8000-000000000001', 'VISITOR', now(), now() + interval '1 day', 'America/Sao_Paulo', 1, '44444444-aaaa-4000-8000-000000000001', 2)$$, '23503', 'request policy version mismatch');
select pg_temp.expect_error($$insert into public.verified_access_requests (condominium_id, unit_id, requested_by_user_id, request_type, starts_at, ends_at, timezone, participant_limit, policy_id, policy_version) values ('11111111-aaaa-4000-8000-000000000001', '22222222-aaaa-4000-8000-000000000001', '33333333-aaaa-4000-8000-000000000001', 'VISITOR', now() + interval '1 day', now(), 'America/Sao_Paulo', 1, '44444444-aaaa-4000-8000-000000000001', 1)$$, '23514', 'invalid request period');

