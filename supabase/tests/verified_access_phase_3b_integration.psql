\set ON_ERROR_STOP on
\set VERBOSITY terse
begin;

insert into public.roles(id,name) values ('13131313-3333-4333-8333-333333333333','VERIFIED_ACCESS_PHASE_3B_TEST_ROLE') on conflict(name) do update set name=excluded.name;
