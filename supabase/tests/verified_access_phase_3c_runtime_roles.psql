\set ON_ERROR_STOP on
begin;

do $$
declare
  v_proc record;
begin
  for v_proc in
    select p.oid
    from pg_proc p
    join pg_namespace n on n.oid = p.pronamespace
    where n.nspname = 'public'
      and p.proname in (
        'verified_access_expire_invitations',
        'verified_access_expire_public_sessions',
        'verified_access_purge_public_commands',
        'verified_access_purge_rate_limit_buckets',
        'verified_access_reconcile_public_registration_state',
        'verified_access_process_outbox',
        'verified_access_apply_retention_policy'
      )
  loop
    if has_function_privilege('anon', v_proc.oid, 'EXECUTE')
       or has_function_privilege('authenticated', v_proc.oid, 'EXECUTE')
       or not has_function_privilege('service_role', v_proc.oid, 'EXECUTE') then
      raise exception 'Phase 3C runtime ACL mismatch';
    end if;
  end loop;
end
$$;

create role verified_access_phase3c_denied_test nologin;
grant verified_access_phase3c_denied_test to postgres;
set role verified_access_phase3c_denied_test;
do $$
begin
  perform public.verified_access_expire_invitations(
    1,
    true,
    'runtime-denied-phase3c'
  );
  raise exception 'synthetic denied role unexpectedly executed maintenance RPC';
exception when insufficient_privilege then
  null;
end
$$;
reset role;
revoke verified_access_phase3c_denied_test from postgres;
drop role verified_access_phase3c_denied_test;

commit;
