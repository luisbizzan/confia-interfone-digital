    "privacy_approval_reference":"PRIV-1C",
    "network_signal_mode":"EVALUATE_ONLY",
    "network_approval_reference":"NET-1C",
    "network_signal_rules":{"min_severity":"HIGH","effects":["REVALIDATE_IDENTITY"]},
    "max_visitor_participants": 5
  }'::jsonb,
  'phase-1c-actor',
  null,
  'phase-1c-create-draft'
) as created_policy_id
\gset

select public.verified_access_create_policy_draft(
  '11111111-1c1c-4000-8000-000000000001',
  '{"visitor_identity_mode":"REQUIRED","privacy_approval_reference":"PRIV-1C"}'::jsonb,
  'phase-1c-actor',
  null,
  'phase-1c-create-draft'
) as repeated_policy_id
\gset

select pg_temp.assert_true(
  :'created_policy_id'::uuid = :'repeated_policy_id'::uuid,
  'create draft idempotency returned the original policy'
);

