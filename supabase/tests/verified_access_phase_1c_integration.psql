create or replace function pg_temp.expect_error(p_sql text, p_expected_sqlstate text, p_label text, p_expected_message text default null)
returns void
language plpgsql
as $$
begin
  execute p_sql;
  raise exception 'Expected % for %', p_expected_sqlstate, p_label
    using errcode = 'ZX001';
exception
  when others then
    if sqlstate <> p_expected_sqlstate then
      raise exception 'Expected %, got % for %', p_expected_sqlstate, sqlstate, p_label;
    end if;

    if p_expected_message is not null and position(p_expected_message in sqlerrm) = 0 then
      raise exception 'Expected message containing %, got % for %', p_expected_message, sqlerrm, p_label;
    end if;
end;
$$;

create or replace function pg_temp.assert_true(p_condition boolean, p_label text)
returns void
language plpgsql
as $$
begin
  if not coalesce(p_condition, false) then
    raise exception 'Assertion failed: %', p_label;
  end if;
end;
$$;

update public.verified_access_requests
set status = 'INVITATIONS_PENDING'
where id = '55555555-1c1c-4000-8000-000000000001';

select pg_temp.expect_error(
  $$update public.verified_access_requests set status = 'DRAFT' where id = '55555555-1c1c-4000-8000-000000000001'$$,
  'P0001',
  'request cannot go backwards',
  'REQUEST_STATUS_TRANSITION_INVALID'
);

