select public.verified_access_activate_policy(
  '11111111-1c1c-4000-8000-000000000001',
  :'created_policy_id',
  'phase-1c-approver',
  'APPROVAL-1C',
  'phase-1c-activate'
) as activated_policy_id
\gset

do $$
declare
  v_active_count integer;
  v_previous_status text;
begin
  select count(*)
    into v_active_count
  from public.verified_access_policies
  where condominium_id = '11111111-1c1c-4000-8000-000000000001'
    and status = 'ACTIVE';

  if v_active_count <> 1 then
    raise exception 'expected exactly one active policy, got %', v_active_count;
  end if;

  select status
    into v_previous_status
  from public.verified_access_policies
  where id = '44444444-1c1c-4000-8000-000000000001';

  if v_previous_status <> 'RETIRED' then
    raise exception 'previous active policy was not retired';
  end if;
end $$;

select pg_temp.expect_error(
  $$update public.verified_access_policies set max_visitor_participants = 8 where id = '44444444-1c1c-4000-8000-000000000001'$$,
  'P0001',
  'retired policy immutable',
  'POLICY_RETIRED_IMMUTABLE'
);

select pg_temp.expect_error(
  format($$select public.verified_access_retire_policy('11111111-1c1c-4000-8000-000000000001', %L::uuid, 'phase-1c-actor', 'RETIRE_ACTIVE')$$, :'created_policy_id'),
  'P0001',
  'active policy cannot be retired directly',
  'POLICY_ACTIVE_REPLACEMENT_REQUIRED'
);

select public.verified_access_create_policy_draft(
  '11111111-1c1c-4000-8000-000000000001',
  '{}'::jsonb,
  'phase-1c-actor',
  :'created_policy_id',
  'phase-1c-create-retire-draft'
) as draft_to_retire_id
\gset

select public.verified_access_retire_policy(
  '11111111-1c1c-4000-8000-000000000001',
  :'draft_to_retire_id',
  'phase-1c-actor',
  'DRAFT_SUPERSEDED',
  'phase-1c-retire-draft'
) as retired_draft_id
\gset

do $$
declare
  v_audit_count integer;
  v_outbox_count integer;
begin
  select count(*)
    into v_audit_count
  from public.verified_access_audit_events
  where condominium_id = '11111111-1c1c-4000-8000-000000000001'
    and event_type in ('POLICY_DRAFT_CREATED', 'POLICY_ACTIVATED', 'POLICY_DRAFT_RETIRED');

  if v_audit_count < 4 then
    raise exception 'expected policy audit events, got %', v_audit_count;
  end if;

  select count(*)
    into v_outbox_count
  from public.verified_access_outbox_events
  where condominium_id = '11111111-1c1c-4000-8000-000000000001'
    and event_type in ('POLICY_DRAFT_CREATED', 'POLICY_ACTIVATED', 'POLICY_DRAFT_RETIRED');

  if v_outbox_count < 4 then
    raise exception 'expected policy outbox events, got %', v_outbox_count;
  end if;
end $$;

select pg_temp.expect_error(
  $$select public.verified_access_write_audit_event('11111111-1c1c-4000-8000-000000000001', 'SERVICE_ROLE', 'phase-1c-actor', 'POLICY', '44444444-1c1c-4000-8000-000000000001', 'BAD', 'BAD', null, '{"cpf":"123"}'::jsonb)$$,
  '22023',
  'audit helper rejects PII aliases',
  'AUDIT_PAYLOAD_FORBIDDEN_PII_ALIAS'
);

do $$
begin
  if exists (
    select 1
    from public.condominium_features
    where feature_key in (
        'VERIFIED_ACCESS',
        'VERIFIED_ACCESS_BACKGROUND_CHECK',
        'VERIFIED_ACCESS_NETWORK_IDENTITY',
        'VERIFIED_ACCESS_NETWORK_SIGNALS',
        'VERIFIED_ACCESS_NETWORK_HOLD'
      )
      and enabled is true
  ) then
    raise exception 'verified access feature flags must remain disabled';
  end if;
end $$;

rollback;
