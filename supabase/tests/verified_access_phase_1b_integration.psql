  ('55555555-1b1b-4000-8000-000000000002', '11111111-1b1b-4000-8000-000000000002', '22222222-1b1b-4000-8000-000000000002', '33333333-1b1b-4000-8000-000000000002', 'VISITOR', now(), now() + interval '1 day', 'America/Sao_Paulo', 1, '44444444-1b1b-4000-8000-000000000002', 1);

