create or replace function pg_temp.expect_error(p_sql text, p_expected_sqlstate text, p_label text)
returns void
language plpgsql
as $$
begin
  execute p_sql;
  raise exception 'Expected % for %', p_expected_sqlstate, p_label
    using errcode = 'ZX001';
exception
  when others then
    if sqlstate <> p_expected_sqlstate then
      raise exception 'Expected %, got % for %', p_expected_sqlstate, sqlstate, p_label;
    end if;
end;
$$;

insert into public.verified_access_network_subject_identifiers (
  network_subject_id,
  identifier_type,
  identifier_hmac,
  hmac_key_version,
  canonicalization_version,
  status,
  is_primary,
  verified_at
)
values (
  '99999999-1b1b-4000-8000-000000000001',
  'CPF',
  repeat('n', 32),
  1,
  1,
  'ACTIVE',
  true,
  now()
);

select pg_temp.expect_error($$insert into public.verified_access_network_subject_identifiers (network_subject_id, identifier_type, identifier_hmac, hmac_key_version, canonicalization_version, verified_at) values ('99999999-1b1b-4000-8000-000000000002', 'CPF', repeat('n', 32), 1, 1, now())$$, '23505', 'duplicate active network HMAC rejected');
select pg_temp.expect_error($$insert into public.verified_access_network_subject_identifiers (network_subject_id, identifier_type, identifier_hmac, hmac_key_version, canonicalization_version, verified_at) values ('99999999-1b1b-4000-8000-000000000001', 'PHONE', repeat('p', 32), 1, 1, now())$$, '23514', 'phone is not a network identifier');
select pg_temp.expect_error($$insert into public.verified_access_network_subject_identifiers (network_subject_id, identifier_type, identifier_hmac, hmac_key_version, canonicalization_version, verified_at) values ('99999999-1b1b-4000-8000-000000000001', 'FACE_TEMPLATE', repeat('f', 32), 1, 1, now())$$, '23514', 'face biometric is not a network identifier');

