do $$
begin
  if exists (
    select 1
    from public.verified_access_network_security_cases
  ) or exists (
    select 1
    from public.verified_access_network_signals
  ) then
    raise exception 'LOCAL_DENIED created a central case or signal';
  end if;
end $$;

