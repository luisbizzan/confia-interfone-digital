select pg_temp.expect_error($$insert into public.verified_access_network_subject_links (network_subject_id, condominium_id, identity_profile_id, assurance_level, link_reason_code) values ('99999999-1b1b-4000-8000-000000000002', '11111111-1b1b-4000-8000-000000000001', '77777777-1b1b-4000-8000-000000000001', 'IDENTITY_VERIFIED', 'DUPLICATE_ACTIVE_PROFILE_LINK')$$, '23505', 'local identity profile has one active network link');

do $$
begin
  if exists (
    select 1
    from public.verified_access_network_signals s
    join public.verified_access_participants p
      on p.identity_profile_id = '77777777-1b1b-4000-8000-000000000001'
    where p.local_decision_reason_code = 'LOCAL_DENIED'
  ) then
    raise exception 'LOCAL_DENIED created a network signal';
  end if;
end $$;

