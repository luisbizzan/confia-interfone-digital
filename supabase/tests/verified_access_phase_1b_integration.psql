create or replace function pg_temp.expect_error(p_sql text, p_expected_sqlstate text, p_label text)
returns void
language plpgsql
as $$
begin
  execute p_sql;
  raise exception 'Expected % for %', p_expected_sqlstate, p_label
    using errcode = 'ZX001';
exception
  when others then
    if sqlstate <> p_expected_sqlstate then
      raise exception 'Expected %, got % for %', p_expected_sqlstate, sqlstate, p_label;
    end if;
end;
$$;

select pg_temp.expect_error($$insert into public.verified_access_network_subjects (status, identity_assurance_level, first_verified_at, last_verified_at) values ('REVALIDATION_REQUIRED', 'IDENTITY_VERIFIED', now(), now())$$, '23514', 'old subject status rejected');
select pg_temp.expect_error($$insert into public.verified_access_network_subjects (id, status, identity_assurance_level, first_verified_at, last_verified_at, merged_into_subject_id) values ('99999999-1b1b-4000-8000-000000000099', 'MERGED', 'IDENTITY_VERIFIED', now(), now(), '99999999-1b1b-4000-8000-000000000099')$$, '23514', 'self merge rejected');

