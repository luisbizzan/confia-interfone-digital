)
values (
  'aaaaaaaa-1b1b-4000-8000-000000000001',
  '99999999-1b1b-4000-8000-000000000001',
  'CONDOMINIUM_REPORT',
  '11111111-1b1b-4000-8000-000000000001',
  '88888888-1b1b-4000-8000-000000000001',
  'OPEN',
  'SECURITY_REVIEW',
  'MEDIUM',
  'MANUAL_VERIFIED',
  'LOCAL_INCIDENT_REVIEW',
  repeat('e', 32),
  '{"reason_code":"LOCAL_INCIDENT_REVIEW"}'::jsonb
);

select pg_temp.expect_error($$insert into public.verified_access_network_security_cases (network_subject_id, source_type, source_condominium_id, source_participant_id, category, severity, evidence_assurance_level, summary_code, evidence_reference_hash, metadata_sanitized) values ('99999999-1b1b-4000-8000-000000000001', 'CONDOMINIUM_REPORT', '11111111-1b1b-4000-8000-000000000002', '88888888-1b1b-4000-8000-000000000001', 'SECURITY_REVIEW', 'MEDIUM', 'MANUAL_VERIFIED', 'CROSS_TENANT_CASE', repeat('x', 32), '{"reason_code":"CROSS_TENANT_CASE"}'::jsonb)$$, '23503', 'cross-tenant case participant rejected');
select pg_temp.expect_error($$insert into public.verified_access_network_security_cases (network_subject_id, source_type, source_condominium_id, source_participant_id, category, severity, evidence_assurance_level, summary_code, evidence_reference_hash, metadata_sanitized) values ('99999999-1b1b-4000-8000-000000000001', 'CONDOMINIUM_REPORT', '11111111-1b1b-4000-8000-000000000001', '88888888-1b1b-4000-8000-000000000001', 'SECURITY_REVIEW', 'MEDIUM', 'MANUAL_VERIFIED', 'BAD_METADATA', repeat('y', 32), '{"cpf":"123"}'::jsonb)$$, '23514', 'central case metadata rejects civil PII aliases');

do $$
begin
  if exists (
    select 1
    from public.verified_access_network_signals
    where network_subject_id = '99999999-1b1b-4000-8000-000000000001'
  ) then
    raise exception 'OPEN security case created a network signal';
  end if;

  if exists (
    select 1
    from public.verified_access_participants
    where condominium_id = '11111111-1b1b-4000-8000-000000000002'
      and network_status <> 'NOT_ENABLED'
  ) then
    raise exception 'OPEN case affected another condominium';
  end if;
end $$;

update public.verified_access_network_security_cases
set status = 'SUBSTANTIATED',
    triaged_at = now(),
    substantiated_at = now()
where id = 'aaaaaaaa-1b1b-4000-8000-000000000001';

select pg_temp.expect_error($$insert into public.verified_access_network_signals (network_subject_id, source_case_id, category, effect, severity, reason_code, policy_version, valid_from, expires_at) values ('99999999-1b1b-4000-8000-000000000001', 'aaaaaaaa-1b1b-4000-8000-000000000001', 'SECURITY_REVIEW', 'AUTO_DENY_NETWORK', 'HIGH', 'AUTO_DENY_NETWORK', 1, now(), now() + interval '30 days')$$, '23514', 'AUTO_DENY_NETWORK is not a valid network effect');
select pg_temp.expect_error($$insert into public.verified_access_network_signals (network_subject_id, source_case_id, category, effect, severity, reason_code, policy_version, valid_from, expires_at) values ('99999999-1b1b-4000-8000-000000000001', 'aaaaaaaa-1b1b-4000-8000-000000000001', 'SECURITY_REVIEW', 'PERMANENT_BLACKLIST', 'HIGH', 'PERMANENT_BLACKLIST', 1, now(), now() + interval '30 days')$$, '23514', 'PERMANENT_BLACKLIST is not a valid network effect');
select pg_temp.expect_error($$insert into public.verified_access_network_signals (network_subject_id, source_case_id, category, effect, severity, reason_code, policy_version, valid_from, expires_at, status) values ('99999999-1b1b-4000-8000-000000000001', 'aaaaaaaa-1b1b-4000-8000-000000000001', 'SECURITY_REVIEW', 'MANUAL_REVIEW_REQUIRED', 'HIGH', 'BAD_WINDOW', 1, now(), now() - interval '1 day', 'PROPOSED')$$, '23514', 'network signal expiration must be after valid_from');

insert into public.verified_access_network_signals (
  id,
  network_subject_id,
  source_case_id,
  category,
  effect,
  status,
  severity,
  reason_code,
  policy_version,
  valid_from,
  expires_at,
  review_due_at,
  activated_at
)
values (
  'bbbbbbbb-1b1b-4000-8000-000000000001',
  '99999999-1b1b-4000-8000-000000000001',
  'aaaaaaaa-1b1b-4000-8000-000000000001',
  'SECURITY_REVIEW',
  'MANUAL_REVIEW_REQUIRED',
  'ACTIVE',
  'HIGH',
  'SUBSTANTIATED_REVIEW',
  1,
  now() + interval '1 hour',
  now() + interval '30 days',
  now() + interval '15 days',
  now()
);

do $$
begin
  if exists (
    select 1
    from public.verified_access_network_signals
    where status = 'ACTIVE'
      and expires_at <= now()
  ) then
    raise exception 'expired active signal can become actionable';
  end if;

  if exists (
    select 1
    from public.verified_access_participants
    where condominium_id = '11111111-1b1b-4000-8000-000000000002'
      and network_status <> 'NOT_ENABLED'
  ) then
    raise exception 'active central signal was propagated to another condominium';
  end if;
end $$;

